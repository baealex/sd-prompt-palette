{
    "name": "sd-prompt-palette-workspace",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "pnpm --parallel --stream --filter @sdpp/server --filter @sdpp/client run dev",
        "start": "pnpm --parallel --stream --filter @sdpp/server --filter @sdpp/client run start",
        "dev:server": "pnpm --filter @sdpp/server run dev",
        "dev:client": "pnpm --filter @sdpp/client run dev",
        "build:server": "pnpm --filter @sdpp/server run build",
        "build:client": "pnpm --filter @sdpp/client run build",
        "start:server": "pnpm --filter @sdpp/server run start",
        "lint:client": "pnpm --filter @sdpp/client run lint",
        "lint": "pnpm --filter @sdpp/server run lint && pnpm --filter @sdpp/client run lint",
        "typecheck:client": "pnpm --filter @sdpp/client run typecheck",
        "test:client": "pnpm --filter @sdpp/client run test",
        "test": "pnpm --filter @sdpp/server run test && pnpm --filter @sdpp/client run test"
    }
}
