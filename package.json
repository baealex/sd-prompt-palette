{
    "name": "ocean-palette",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "pnpm --parallel --stream --filter @ocean-palette/server --filter @ocean-palette/client run dev",
        "start": "pnpm build:client && pnpm start:server",
        "dev:server": "pnpm --filter @ocean-palette/server run dev",
        "dev:client": "pnpm --filter @ocean-palette/client run dev",
        "build:server": "pnpm --filter @ocean-palette/server run build",
        "build:client": "pnpm --filter @ocean-palette/client run build",
        "start:server": "pnpm --filter @ocean-palette/server run start",
        "biome:format": "biome format --write",
        "lint:client": "pnpm --filter @ocean-palette/client run lint",
        "lint": "pnpm --filter @ocean-palette/server run lint && pnpm --filter @ocean-palette/client run lint",
        "guard:agent-rules": "node scripts/guardrails/check-agent-rules.mjs",
        "guard:function-params": "node scripts/guardrails/check-function-params.mjs",
        "guard:ui-contract": "node scripts/guardrails/check-ui-contract.mjs",
        "hooks:install": "lefthook install",
        "typecheck:client": "pnpm --filter @ocean-palette/client run typecheck",
        "test:client": "pnpm --filter @ocean-palette/client run test",
        "test": "pnpm --filter @ocean-palette/server run test && pnpm --filter @ocean-palette/client run test"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
        "lefthook": "^1.11.2"
    },
    "pnpm": {
        "overrides": {
            "tar": "7.5.8",
            "esbuild": "0.25.0"
        }
    }
}
